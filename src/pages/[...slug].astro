---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import LegacyHomeLayout from '../layouts/LegacyHomeLayout.astro'
import SlideLayout from '../layouts/SlideLayout.astro'
import {
  getChildren,
  getEntryByUrl,
  getStaticPathsForEntries,
  getTranslations,
  type Entry,
} from '../lib/content'
import { renderHtml, renderInline } from '../lib/markdown'
import '../styles/global.css'

export function getStaticPaths() {
  return getStaticPathsForEntries()
}

const rawSlug = Astro.params.slug
const slug = rawSlug ? rawSlug.split('/').filter(Boolean) : []
const urlPath = `/${slug.join('/')}/`

const entry = getEntryByUrl(urlPath)
if (!entry) {
  Astro.response.status = 404
}

function asStringArray(value: unknown): string[] {
  if (!Array.isArray(value)) return []
  return value.filter((item): item is string => typeof item === 'string')
}

function renderPostLinks(item: Entry): string {
  const alsoAvailable = asStringArray(item.frontmatter.alsoAvailable)
  const discussedOn = asStringArray(item.frontmatter.discussedOn)

  const lines: string[] = []
  if (alsoAvailable.length > 0) {
    const links = alsoAvailable
      .map((href, idx) => `<a target="_blank" rel="noopener noreferrer" href="${href}">[${idx + 1}]</a>`)
      .join(' ')
    lines.push(`<i>${item.lang === 'pt' ? 'Também disponível em' : 'Also available on'}: ${links}</i><br/>`)
  }

  if (discussedOn.length > 0) {
    const links = discussedOn
      .map((href, idx) => `<a target="_blank" rel="noopener noreferrer" href="${href}">[${idx + 1}]</a>`)
      .join(' ')
    lines.push(`<i>${item.lang === 'pt' ? 'Discutido em' : 'Discussed on'}: ${links}</i><br/>`)
  }

  return lines.join('\n')
}

function splitSlideSections(item: Entry): string[] {
  return item.body
    .split(/\n---\n/g)
    .map((chunk) => chunk.trim())
    .filter(Boolean)
    .map((chunk) => chunk.replaceAll(
      '%auto-animate%',
      '<script>document.currentScript.parentNode.setAttribute("data-auto-animate", "1")</script>',
    ))
    .map((chunk) => renderHtml(chunk, item))
}

const isSlide = entry
  ? entry.slugSegments.length >= 2 && entry.slugSegments[0] === 'utils' && entry.slugSegments[1] === 'slides'
  : false

const isBase16 = entry
  ? entry.slugSegments.length >= 2 && entry.slugSegments[0] === 'utils' && entry.slugSegments[1] === 'base16'
  : false

const isLegacyHome = entry
  ? entry.slugSegments.length >= 2 && entry.slugSegments[0] === 'utils' && entry.slugSegments[1] === 'home'
  : false

const isPostPage = entry
  ? entry.kind === 'page' && entry.slugSegments.length === 2 && entry.slugSegments[0] === 'post'
  : false

const translations = entry ? getTranslations(entry) : []
const html = entry ? renderHtml(entry.body, entry) : ''
const children = entry ? getChildren(entry) : []

const posts = await getCollection('posts')
const postById = new Map(posts.map((post) => [post.id, post] as const))
const postId = isPostPage && entry ? `${entry.lang}/${entry.slugSegments[1]}` : null
const postItem = postId ? postById.get(postId) : null
const postRendered = postItem ? await render(postItem) : null
const PostContent = postRendered?.Content
---

{
  !entry ? (
    <BaseLayout entry={{
      id: '404',
      lang: 'en',
      kind: 'page',
      slugSegments: ['404'],
      title: 'Not Found',
      body: '',
      frontmatter: {},
      aliases: [],
      url: '/en/404/',
      sourceFile: '',
    }} translations={[]}>
      <h1>Not found</h1>
      <p>No content matched this route.</p>
    </BaseLayout>
  ) : isSlide ? (
    <SlideLayout entry={entry} sections={splitSlideSections(entry)} />
  ) : isLegacyHome ? (
    <LegacyHomeLayout
      lang={entry.lang}
      title={entry.title}
      quotes={asStringArray(entry.frontmatter.quotes)}
    />
  ) : (
    <BaseLayout entry={entry} translations={translations}>
      {entry.kind === 'page' && !isBase16 ? <h1>{entry.title}</h1> : null}
      {entry.kind === 'page' && !isBase16 ? <Fragment set:html={renderPostLinks(entry)} /> : null}

      {isBase16 && entry.kind === 'section' ? (
        <section>
          <Fragment set:html={html} />
          {children.map((child) => (
            <div class="theme-card">
              <div class="theme-card-info-container">
                <a href={child.url}>
                  <h2>{child.title}</h2>
                  <p>{typeof child.frontmatter.author === 'string' ? child.frontmatter.author : ''}</p>
                </a>
              </div>
              <div class="theme-card-sample-container">
                {asStringArray(child.frontmatter.colors).map((color) => (
                  <div class="theme-card-color-container" style={`background-color: #${color}`}>
                    <p>#{color}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </section>
      ) : isBase16 && entry.kind === 'page' ? (
        <section>
          <h1>{entry.title}</h1>
          {entry.summary ? <p set:html={renderInline(entry.summary)} /> : null}
          <Fragment set:html={html} />
          <p>by {typeof entry.frontmatter.author === 'string' ? entry.frontmatter.author : ''}</p>
          <div class="theme-card-sample-container">
            {asStringArray(entry.frontmatter.colors).map((color) => (
              <div class="theme-card-color-container" style={`background-color: #${color}`}>
                <p>#{color}</p>
              </div>
            ))}
          </div>
        </section>
      ) : entry.kind === 'section' ? (
        <section>
          <Fragment set:html={html} />
          {children.map((child) => (
            <div class="card bg-base-200 shadow-sm m-2">
              <div class="card-body">
                <a href={child.url}>
                  <h2 class="card-title">{child.title}</h2>
                  <p>{child.summary ?? ''}</p>
                </a>
              </div>
            </div>
          ))}
        </section>
      ) : isPostPage && PostContent ? (
        <PostContent />
      ) : (
        <Fragment set:html={html} />
      )}
    </BaseLayout>
  )
}

{
  !isLegacyHome ? (
    <style>
      :root {
        --color-cell-size: 4.5em;
      }

      .theme-card {
        width: 100%;
      }

      .theme-card-sample-container {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
      }

      .theme-card-info-container {
        display: flex;
        align-items: center;
        flex-direction: row;
        justify-content: space-between;
      }

      .theme-card-info-container h2 {
        margin-right: 3rem;
        white-space: nowrap;
      }

      .theme-card-info-container p {
        text-align: right;
      }

      .theme-card-color-container {
        width: var(--color-cell-size);
        height: var(--color-cell-size);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .theme-card-color-container p {
        background-color: initial;
        padding: 0.1rem;
        border-radius: 0.05rem;
        margin: 0.5rem;
        font-family: "Courier New", monospace;
        text-transform: uppercase;
      }
    </style>
  ) : null
}
