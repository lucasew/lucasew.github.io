---
import ContentEntry from '../../../components/ContentEntry.astro'
import {
  getEntryByUrl,
  getStaticPathsForSegments,
} from '../../../lib/content'

export function getStaticPaths() {
  return getStaticPathsForSegments(['lang', 'segment'])
}

const { lang, segment } = Astro.params
const urlPath = `/${lang}/${segment}/`
const entry = getEntryByUrl(urlPath)
if (!entry) {
  Astro.response.status = 404
}
---

{entry ? <ContentEntry entry={entry} /> : null}
