---
import ContentEntry from '../../../components/ContentEntry.astro'
import {
  getEntryByUrl,
  getKnownUrls,
} from '../../../lib/content'

export function getStaticPaths() {
  return getKnownUrls()
    .map((urlPath) => urlPath.split('/').filter(Boolean))
    .filter((parts) => parts.length === 2)
    .map(([lang, segment]) => ({ params: { lang, segment } }))
}

const { lang, segment } = Astro.params
const urlPath = `/${lang}/${segment}/`
const entry = getEntryByUrl(urlPath)
if (!entry) {
  Astro.response.status = 404
}
---

{entry ? <ContentEntry entry={entry} /> : null}
