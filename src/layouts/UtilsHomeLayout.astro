---
import type { Lang } from '../lib/i18n'
import avatarSvg from '../assets/utils-home-avatar.svg?raw'

interface Props {
  lang: Lang
  title: string
  quotes: string[]
}

const { lang, title, quotes } = Astro.props
const homeHref = `/${lang}/`
---

<!doctype html>
<html lang={lang} dir="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <meta http-equiv="refresh" content={`8; URL=${homeHref}`} />
    <title>{title}</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/sakura.css/css/normalize.css"
      type="text/css"
    />
  </head>
  <body>
    <style is:global>
      :root {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans',
          sans-serif;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      #container {
        display: flex;
        overflow: auto;
        flex: none;
        width: 100%;
        height: 100vh;
        overflow-y: scroll;
        flex-flow: column nowrap;
        scroll-snap-type: y mandatory;
      }

      #container > section {
        width: 100%;
        height: 100%;
        scroll-snap-align: start;
        flex: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-direction: column;
      }

      section#firstpage {
        background-color: #65c9ff;
      }

      section#firstpage > svg {
        justify-self: flex-end;
        animation: appear 1s;
      }

      section#firstpage h1 {
        text-align: center;
        font-size: 2rem;
        animation: fadeIn 0.5s;
      }

      div#title-contact {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      div#title-contact > * {
        padding: 1rem;
      }

      p#frase {
        transition: opacity 1s linear 0s;
        opacity: 0;
      }

      g#eyes > * {
        animation: blink 5s infinite;
      }

      @keyframes fadeIn {
        0% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }

      @keyframes appear {
        0% {
          margin-bottom: -300px;
        }
        100% {
          margin-bottom: 0;
        }
      }

      @keyframes blink {
        0% {
          opacity: 1;
        }
        94% {
          opacity: 1;
        }
        97% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }
    </style>

    <div id="container">
      <section id="firstpage">
        <div></div>
        <div></div>
        <div id="title-contact">
          <h1>Lucas Eduardo Wendt 🇧🇷</h1>
          <p id="frase"></p>
        </div>
        <Fragment set:html={avatarSvg} />
      </section>
    </div>

    <script define:vars={{ quotes }}>
      const el = document.getElementById('frase')
      if (el && Array.isArray(quotes) && quotes.length > 0) {
        const quote = quotes[Math.floor(Math.random() * quotes.length)]
        el.textContent = quote
        setTimeout(() => {
          el.style.opacity = '1'
        }, 1000)
      }
    </script>
  </body>
</html>
