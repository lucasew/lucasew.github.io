---
import type { Lang } from '../lib/i18n'
import avatarSvg from '../assets/utils-home-avatar.svg?raw'
import BaseHead from '../components/BaseHead.astro'

interface Props {
  lang: Lang
  title: string
  quotes: string[]
}

const { lang, title, quotes } = Astro.props
const homeHref = `/${lang}/`
---

<!doctype html>
<html lang={lang} dir="auto">
  <head>
    <BaseHead
      title={title}
      robots="index, follow"
    >
      <meta http-equiv="refresh" content={`8; URL=${homeHref}`} />
      <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/sakura.css/css/normalize.css"
        type="text/css"
      />
    </BaseHead>
  </head>
  <body>
    {/*
      Styles must stay under .utils-home. This layout is imported by the same
      route module as normal posts ([section]/[slug]), so unscoped / is:global
      rules (especially `* { margin:0; padding:0 }`) leak into article prose.
    */}
    <style is:global>
      .utils-home {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans',
          sans-serif;
      }

      .utils-home,
      .utils-home * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      .utils-home {
        display: flex;
        overflow: auto;
        flex: none;
        width: 100%;
        height: 100vh;
        overflow-y: scroll;
        flex-flow: column nowrap;
        scroll-snap-type: y mandatory;
      }

      .utils-home > section {
        width: 100%;
        height: 100%;
        scroll-snap-align: start;
        flex: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-direction: column;
      }

      .utils-home > section#firstpage {
        background-color: #65c9ff;
      }

      .utils-home > section#firstpage > svg {
        justify-self: flex-end;
        animation: utils-home-appear 1s;
      }

      .utils-home > section#firstpage h1 {
        text-align: center;
        font-size: 2rem;
        animation: utils-home-fade-in 0.5s;
      }

      .utils-home #title-contact {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .utils-home #title-contact > * {
        padding: 1rem;
      }

      .utils-home #frase {
        transition: opacity 1s linear 0s;
        opacity: 0;
      }

      .utils-home g#eyes > * {
        animation: utils-home-blink 5s infinite;
      }

      @keyframes utils-home-fade-in {
        0% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }

      @keyframes utils-home-appear {
        0% {
          margin-bottom: -300px;
        }
        100% {
          margin-bottom: 0;
        }
      }

      @keyframes utils-home-blink {
        0% {
          opacity: 1;
        }
        94% {
          opacity: 1;
        }
        97% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }
    </style>

    <div class="utils-home" id="container">
      <section id="firstpage">
        <div></div>
        <div></div>
        <div id="title-contact">
          <h1>Lucas Eduardo Wendt 🇧🇷</h1>
          <p id="frase"></p>
        </div>
        <Fragment set:html={avatarSvg} />
      </section>
    </div>

    <script define:vars={{ quotes }}>
      const el = document.getElementById('frase')
      if (el && Array.isArray(quotes) && quotes.length > 0) {
        const quote = quotes[Math.floor(Math.random() * quotes.length)]
        el.textContent = quote
        setTimeout(() => {
          el.style.opacity = '1'
        }, 1000)
      }
    </script>
  </body>
</html>
