---
import { ClientRouter, slide } from 'astro:transitions'
import ProgressBar from '../components/ProgressBar.astro'
import SiteIcon from '../components/SiteIcon.astro'
import BaseHead from '../components/BaseHead.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import { getSectionTitle, type Entry } from '../lib/content'
import { t } from '../lib/i18n'
import '../styles/global.css'

interface Props {
  entry: Entry
  translations: Entry[]
}

const { entry, translations } = Astro.props
const postTitle = getSectionTitle(entry.lang, ['post']) || t(entry.lang, 'posts')
const utilsTitle = getSectionTitle(entry.lang, ['utils']) || t(entry.lang, 'utilities')
---

<!doctype html>
<html lang={entry.lang}>
  <head>
    <BaseHead
      title={entry.title}
      description={entry.summary ?? ''}
      robots="index, follow"
      mdpath={entry.sourceFile}
    >
      <link rel="alternate" type="application/rss+xml" title={t(entry.lang, 'rss-title')} href={`/${entry.lang}/post/index.xml`} />
      <script is:inline>
        const themeKey = 'theme'
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        const savedTheme = localStorage.getItem(themeKey) ?? (prefersDark ? 'dark' : 'light')
        document.documentElement.setAttribute('data-theme', savedTheme)
      </script>
      <ClientRouter />
      <script
        is:inline
        defer
        src="https://analytics.app.lew.tec.br/script.js"
        data-website-id="01c5a581-3c67-4ef4-8820-6701611d8b70"
        data-host-url="https://analytics.app.lew.tec.br"
      ></script>
    </BaseHead>
  </head>
  <body>
    <ProgressBar />
    <header>
      <nav class="navbar">
        <div class="navbar-start">
          <a href={`/${entry.lang}/`} class="flex items-center gap-2">
            <SiteIcon id="icon" class="block m-0" size="2rem" />
            <b class="leading-none">{t(entry.lang, 'site-title')}</b>
          </a>
        </div>

        <div class="navbar-end [&>*]:mx-1">
          <a href={`/${entry.lang}/utils/`}>{utilsTitle}</a>
          <a href={`/${entry.lang}/post/`}>{postTitle}</a>
          {translations.map((translation) => (
            <a href={translation.url}>{translation.lang === 'pt' ? '🇧🇷' : '🇺🇸'}</a>
          ))}
          <ThemeToggle />
        </div>
      </nav>
    </header>

    <main class="prose mx-auto" transition:animate={slide()}>
      <slot />
    </main>
  </body>
</html>
