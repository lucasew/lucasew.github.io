---
import type { Entry } from '../lib/content'

interface Props {
  entry: Entry
  sections: string[]
}

const { entry, sections } = Astro.props
const logo = typeof entry.frontmatter.logo === 'string' ? entry.frontmatter.logo : '/icon.png'
---

<!doctype html>
<html lang={entry.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={entry.summary ?? ''} />
    <title>{entry.title}</title>

  </head>
  <body>
    <img
      id="logo"
      src={logo}
      alt="logo"
      style="position:absolute;top:20px;left:20px;width:2rem;max-width:2rem;max-height:2rem;"
    />

    <div class="reveal">
      <div class="slides">
        {sections.map((section) => (
          <section set:html={section} />
        ))}
      </div>
    </div>

    <script>
      import 'reveal.js/reset.css'
      import 'reveal.js/reveal.css'
      import 'reveal.js/theme/black.css'
      import Reveal from 'reveal.js'
      import RevealMath from 'reveal.js/plugin/math'
      import RevealZoom from 'reveal.js/plugin/zoom'

      const deck = new Reveal({
        plugins: [RevealMath.KaTeX, RevealZoom],
      })
      deck.initialize()
    </script>
  </body>
</html>
