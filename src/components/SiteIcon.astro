---
import defaultIconInline from '../assets/icon.png?inline'

interface Props {
  href?: string
  src?: string
  alt?: string
  size?: string
  id?: string
  class?: string
  style?: string
  wrapperClass?: string
  wrapperStyle?: string
}

const {
  href,
  src = defaultIconInline,
  alt = 'icon',
  size,
  id,
  class: className = '',
  style = '',
  wrapperClass = '',
  wrapperStyle = '',
} = Astro.props

const sizeStyle = size ? `width:${size};max-width:${size};max-height:${size};` : ''
const imgStyle = `${sizeStyle}${style}`.trim()
---

{
  href ? (
    <a href={href} class={wrapperClass} style={wrapperStyle}>
      <img id={id} class={className} src={src} alt={alt} style={imgStyle} />
    </a>
  ) : (
    <img id={id} class={className} src={src} alt={alt} style={imgStyle} />
  )
}
