---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import {
  getChildren,
  getTranslations,
  type Entry,
} from '../lib/content'
import { t } from '../lib/i18n'
import { renderHtml } from '../lib/markdown'

interface Props {
  entry: Entry
}

const { entry } = Astro.props

function asStringArray(value: unknown): string[] {
  if (!Array.isArray(value)) return []
  return value.filter((item): item is string => typeof item === 'string')
}

function renderPostLinks(item: Entry): string {
  const alsoAvailable = asStringArray(item.frontmatter.alsoAvailable)
  const discussedOn = asStringArray(item.frontmatter.discussedOn)

  const lines: string[] = []
  if (alsoAvailable.length > 0) {
    const links = alsoAvailable
      .map((href, idx) => `<a target="_blank" rel="noopener noreferrer" href="${href}">[${idx + 1}]</a>`)
      .join(' ')
    lines.push(`<i>${t(item.lang, 'also-available-on')}: ${links}</i><br/>`)
  }

  if (discussedOn.length > 0) {
    const links = discussedOn
      .map((href, idx) => `<a target="_blank" rel="noopener noreferrer" href="${href}">[${idx + 1}]</a>`)
      .join(' ')
    lines.push(`<i>${t(item.lang, 'discussed-on')}: ${links}</i><br/>`)
  }

  return lines.join('\n')
}

const isPostPage = entry.kind === 'page' && entry.slugSegments.length === 2 && entry.slugSegments[0] === 'post'

const translations = getTranslations(entry)
const html = renderHtml(entry.body, entry)
const children = getChildren(entry)

const posts = await getCollection('posts')
const postById = new Map(posts.map((post) => [post.id, post] as const))
const postId = isPostPage ? `${entry.lang}/${entry.slugSegments[1]}` : null
const postItem = postId ? postById.get(postId) : null
const postRendered = postItem ? await render(postItem) : null
const PostContent = postRendered?.Content
---

<BaseLayout entry={entry} translations={translations}>
  {entry.kind === 'page' ? <h1>{entry.title}</h1> : null}
  {entry.kind === 'page' ? <Fragment set:html={renderPostLinks(entry)} /> : null}

  {entry.kind === 'section' ? (
    <section>
      <Fragment set:html={html} />
      {children.map((child) => (
        <div class="card bg-base-200 shadow-sm m-2">
          <div class="card-body">
            <a href={child.url}>
              <h2 class="card-title">{child.title}</h2>
              <p>{child.summary ?? ''}</p>
            </a>
          </div>
        </div>
      ))}
    </section>
  ) : isPostPage && PostContent ? (
    <PostContent />
  ) : (
    <Fragment set:html={html} />
  )}
  <div id="article-end"></div>
</BaseLayout>
