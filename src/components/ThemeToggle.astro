<label class="swap swap-rotate" title="Toggle theme">
  <input
    id="theme-toggle"
    type="checkbox"
    aria-label="Toggle theme"
    value="dark"
  />
  <span class="swap-on text-xl">☀️</span>
  <span class="swap-off text-xl">🌙</span>
</label>

<script>
  const themeKey = 'theme'

  function getTheme() {
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
    return localStorage.getItem(themeKey) ?? (prefersDark ? 'dark' : 'light')
  }

  function applyTheme() {
    const theme = getTheme()
    document.documentElement.setAttribute('data-theme', theme)

    const toggle = document.getElementById('theme-toggle')
    if (toggle instanceof HTMLInputElement) {
      toggle.checked = theme === 'dark'
    }
  }

  function setupThemeListeners() {
    const toggle = document.getElementById('theme-toggle')
    let toggleHandler: ((event: Event) => void) | null = null
    if (toggle instanceof HTMLInputElement) {
      toggleHandler = (event: Event) => {
        const target = event.target
        if (!(target instanceof HTMLInputElement)) return

        const nextTheme = target.checked ? 'dark' : 'light'
        localStorage.setItem(themeKey, nextTheme)
        document.documentElement.setAttribute('data-theme', nextTheme)
      }
      toggle.addEventListener('change', toggleHandler)
    }

    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)')
    const mediaHandler = () => {
      if (!localStorage.getItem(themeKey)) {
        applyTheme()
      }
    }
    mediaQuery.addEventListener('change', mediaHandler)

    document.addEventListener(
      'astro:before-swap',
      () => {
        if (toggle instanceof HTMLInputElement && toggleHandler) {
          toggle.removeEventListener('change', toggleHandler)
        }
        mediaQuery.removeEventListener('change', mediaHandler)
      },
      { once: true },
    )
  }

  applyTheme()
  document.addEventListener('astro:after-swap', applyTheme)
  document.addEventListener('astro:page-load', setupThemeListeners)
</script>
